// ---------------- installment contracts ----------------
model InstallmentContract {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id            String   @db.Uuid
  branch               Branch   @relation(fields: [branch_id], references: [id])
  contract_code        String   @unique @db.VarChar(50)
  customer_id          String   @db.Uuid
  customer             Customer @relation(fields: [customer_id], references: [id])
  repayment_amount     Decimal  @default(0) @db.Decimal(15, 2)
  disbursed_amount     Decimal  @default(0) @db.Decimal(15, 2)
  period_type          String   @db.VarChar(20) // 'daily', 'monthly'
  loan_duration        Int
  cycle_days           Int      @default(1)
  is_upfront_collected Boolean  @default(false)
  loan_date            DateTime @db.Date
  collector_id         String   @db.Uuid
  collector            Employee @relation("collector_installment_contracts", fields: [collector_id], references: [id])
  collaborator_id      String?  @db.Uuid
  collaborator         Collaborator? @relation(fields: [collaborator_id], references: [id])
  debt_amount          Decimal  @default(0) @db.Decimal(15, 2)
  status               String   @default("active") @db.VarChar(20)
  notes                String?  @db.Text
  created_at           DateTime @default(now()) @db.Timestamptz
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz
  lookup_token         String?  @db.VarChar(100)
  lookup_link          String?  @db.VarChar(255)

  payments            InstallmentPayment[]
  redemptions         InstallmentRedemption[]
  debt_history        InstallmentDebtHistory[]
  documents           InstallmentContractDocument[]
  debt_reminders      InstallmentDebtReminder[]
  transaction_ledgers InstallmentTransactionLedger[]
  reminders           InstallmentContractReminder[]

  @@index([branch_id])
  @@index([customer_id])
  @@index([status])
  @@index([loan_date])
  @@map("installment_contracts")
}

model InstallmentPayment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
