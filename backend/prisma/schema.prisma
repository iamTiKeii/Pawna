datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

model Branch {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String   @unique @db.VarChar(150)
  investment_capital Decimal  @default(0) @db.Decimal(15, 2)
  status             String   @default("active") @db.VarChar(20)
  address            String?  @db.Text
  phone              String?  @db.VarChar(20)
  opening_date       DateTime? @db.Date
  manager_id         String?  @db.Uuid
  notes              String?  @db.Text
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz

  employees             UserBranch[]
  daily_cash            DailyCash[]
  cash_fund_history     CashFundHistory[]
  customers             Customer[]
  capital_contracts     CapitalContract[]
  pawn_contracts        PawnContract[]
  unsecured_contracts   UnsecuredContract[]
  installment_contracts InstallmentContract[]
  payment_vouchers      PaymentVoucher[]
  receipt_vouchers      ReceiptVoucher[]
  customer_blacklists   CustomerBlacklist[]
  warnings_reminders    Reminder[]

  @@map("branches")
}

model UserBranch {
  user_id   String   @db.Uuid
  employee  Employee @relation(fields: [user_id], references: [id], onDelete: Cascade)
  branch_id String   @db.Uuid
  branch    Branch   @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  @@id([user_id, branch_id])
  @@map("user_branches")
}

model Employee {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username           String   @unique @db.VarChar(50)
  password_hash      String   @db.VarChar(255)
  full_name          String   @db.VarChar(100)
  phone              String?  @db.VarChar(20)
  email              String?  @db.VarChar(100)
  avatar_url         String?  @db.Text
  address            String?  @db.Text
  gender             String?  @db.VarChar(20)
  birthday           DateTime? @db.Date
  two_factor_secret  String?  @db.Text
  two_factor_enabled Boolean  @default(false)
  bank_name          String?  @db.VarChar(100)
  bank_account_number String? @db.VarChar(50)
  bank_account_holder String? @db.VarChar(100)
  status             String   @default("active") @db.VarChar(20)
  failed_login_attempts Int   @default(0)
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz

  branches                       UserBranch[]
  permissions                    EmployeePermission[]
  pawn_contracts                 PawnContract[]                 @relation("collector_pawn_contracts")
  unsecured_contracts           UnsecuredContract[]           @relation("collector_unsecured_contracts")
  installment_contracts         InstallmentContract[]         @relation("collector_installment_contracts")
  payment_vouchers              PaymentVoucher[]
  receipt_vouchers              ReceiptVoucher[]
  cash_fund_history             CashFundHistory[]
  pawn_debt_reminders           PawnDebtReminder[]
  unsecured_debt_reminders      UnsecuredDebtReminder[]
  installment_debt_reminders    InstallmentDebtReminder[]
  pawn_transaction_ledgers      PawnTransactionLedger[]
  unsecured_transaction_ledgers UnsecuredTransactionLedger[]
  installment_transaction_ledgers InstallmentTransactionLedger[]
  reported_blacklists           CustomerBlacklist[]
  warnings_reminders            Reminder[]

  @@map("employees")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  category    String   @db.VarChar(50)
  description String?  @db.Text

  employees EmployeePermission[]

  @@map("permissions")
}

model EmployeePermission {
  employee_id   String     @db.Uuid
  employee      Employee   @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  permission_id String     @db.Uuid
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([employee_id, permission_id])
  @@map("employee_permissions")
}

model InterestType {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String   @unique @db.VarChar(50)
  name                  String   @db.VarChar(100)
  calculation_method    String   @db.VarChar(50)
  is_principal_included Boolean  @default(false)
  status                String   @default("active") @db.VarChar(20)
  notes                 String?  @db.Text
  description           String?  @db.Text
  is_system             Boolean  @default(true)
  created_at            DateTime @default(now()) @db.Timestamptz
  updated_at            DateTime @default(now()) @updatedAt @db.Timestamptz

  commodities         Commodity[]
  capital_contracts   CapitalContract[]
  pawn_contracts      PawnContract[]
  unsecured_contracts UnsecuredContract[]

  @@map("interest_types")
}

model Commodity {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category               String   @db.VarChar(20) // 'pawn' or 'unsecured'
  code                   String   @unique @db.VarChar(50)
  name                   String   @db.VarChar(150)
  status                 String   @default("active") @db.VarChar(20)
  interest_type_id       String   @db.Uuid
  interest_type          InterestType @relation(fields: [interest_type_id], references: [id])
  is_upfront_interest    Boolean  @default(false)
  default_amount         Decimal  @default(0) @db.Decimal(15, 2)
  default_interest_rate  Decimal  @default(0) @db.Decimal(10, 2)
  default_period_value   Int      @default(15)
  default_loan_days      Int      @default(30)
  liquidation_after_days Int      @default(10)
  created_at             DateTime @default(now()) @db.Timestamptz
  updated_at             DateTime @default(now()) @updatedAt @db.Timestamptz

  pawn_contracts      PawnContract[]
  unsecured_contracts UnsecuredContract[]

  @@map("commodities")
}

model DailyCash {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id      String   @db.Uuid
  branch         Branch   @relation(fields: [branch_id], references: [id])
  date           DateTime @db.Date
  beginning_cash Decimal  @default(0) @db.Decimal(15, 2)
  current_cash   Decimal  @default(0) @db.Decimal(15, 2)
  physical_cash  Decimal  @default(0) @db.Decimal(15, 2)
  is_locked      Boolean  @default(false)
  locked_at      DateTime? @db.Timestamptz
  locked_by      String?  @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz

  @@unique([branch_id, date])
  @@map("daily_cash")
}

model CashFundHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id   String   @db.Uuid
  branch      Branch   @relation(fields: [branch_id], references: [id])
  date        DateTime @db.Date
  employee_id String   @db.Uuid
  employee    Employee @relation(fields: [employee_id], references: [id])
  amount      Decimal  @db.Decimal(15, 2)
  type        String   @db.VarChar(30)
  description String   @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz

  @@map("cash_fund_history")
}

model Collaborator {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name           String   @db.VarChar(100)
  code                String   @unique @db.VarChar(50)
  phone               String?  @db.VarChar(20)
  bank_name           String?  @db.VarChar(100)
  bank_account_number String?  @db.VarChar(50)
  bank_account_holder String?  @db.VarChar(100)
  status              String   @default("active") @db.VarChar(20)
  created_at          DateTime @default(now()) @db.Timestamptz
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz

  pawn_contracts        PawnContract[]
  unsecured_contracts   UnsecuredContract[]
  installment_contracts InstallmentContract[]

  @@map("collaborators")
}

model Customer {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id            String    @db.Uuid
  branch               Branch    @relation(fields: [branch_id], references: [id])
  full_name            String    @db.VarChar(100)
  phone                String?   @db.VarChar(20)
  address              String?   @db.Text
  identity_card_number String?   @db.VarChar(50)
  identity_card_date   DateTime? @db.Date
  identity_card_place  String?   @db.VarChar(150)
  spouse_name          String?   @db.VarChar(100)
  spouse_phone         String?   @db.VarChar(20)
  spouse_job           String?   @db.VarChar(100)
  father_name          String?   @db.VarChar(100)
  father_phone         String?   @db.VarChar(20)
  father_job           String?   @db.VarChar(100)
  mother_name          String?   @db.VarChar(100)
  mother_phone         String?   @db.VarChar(20)
  mother_job           String?   @db.VarChar(100)
  status               String    @default("active") @db.VarChar(20) // active, inactive, blacklist
  notes                String?   @db.Text
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz

  pawn_contracts        PawnContract[]
  unsecured_contracts   UnsecuredContract[]
  installment_contracts InstallmentContract[]
  blacklist_records     CustomerBlacklist[]
  capital_contracts     CapitalContract[]

  @@index([branch_id])
  @@index([status])
  @@index([phone])
  @@index([identity_card_number])
  @@map("customers")
}

model CustomerBlacklist {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String   @db.Uuid
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  reporter_id String   @db.Uuid
  reporter    Employee @relation(fields: [reporter_id], references: [id])
  branch_id   String   @db.Uuid
  branch      Branch   @relation(fields: [branch_id], references: [id])
  reason      String   @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("customer_blacklist")
}

model CapitalContract {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id           String   @db.Uuid
  branch              Branch   @relation(fields: [branch_id], references: [id])
  customer_id         String?  @db.Uuid
  customer            Customer? @relation(fields: [customer_id], references: [id])
  investor_name       String   @db.VarChar(100)
  investor_id_card    String?  @db.VarChar(50)
  investor_phone      String?  @db.VarChar(20)
  investor_address    String?  @db.Text
  amount              Decimal  @default(0) @db.Decimal(15, 2)
  investment_date     DateTime @db.Date
  interest_type_id    String?  @db.Uuid
  interest_type       InterestType? @relation(fields: [interest_type_id], references: [id])
  is_upfront_interest Boolean  @default(false)
  status              String   @default("active") @db.VarChar(20)
  notes               String?  @db.Text
  created_at          DateTime @default(now()) @db.Timestamptz
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz

  transactions        CapitalTransaction[]

  @@map("capital_contracts")
}

model CapitalTransaction {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id      String          @db.Uuid
  contract         CapitalContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  type             String          @db.VarChar(50) // "interest", "withdraw_principal", "add_principal", "extend", "withdraw_all"
  amount           Decimal         @default(0) @db.Decimal(15, 2)
  transaction_date DateTime        @db.Date
  notes            String?         @db.Text
  created_at       DateTime        @default(now()) @db.Timestamptz
  updated_at       DateTime        @default(now()) @updatedAt @db.Timestamptz

  @@map("capital_transactions")
}

// ---------------- pawn contracts ----------------
model PawnContract {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id           String   @db.Uuid
  branch              Branch   @relation(fields: [branch_id], references: [id])
  contract_code       String   @unique @db.VarChar(50)
  customer_id         String   @db.Uuid
  customer            Customer @relation(fields: [customer_id], references: [id])
  commodity_id        String   @db.Uuid
  commodity           Commodity @relation(fields: [commodity_id], references: [id])
  asset_name          String   @db.VarChar(150)
  loan_amount         Decimal  @default(0) @db.Decimal(15, 2)
  interest_type_id    String   @db.Uuid
  interest_type       InterestType @relation(fields: [interest_type_id], references: [id])
  is_upfront_interest Boolean
  loan_days           Int
  period_value        Int
  interest_rate       Decimal  @db.Decimal(10, 2)
  loan_date           DateTime @db.Date
  collector_id        String   @db.Uuid
  collector           Employee @relation("collector_pawn_contracts", fields: [collector_id], references: [id])
  collaborator_id     String?  @db.Uuid
  collaborator        Collaborator? @relation(fields: [collaborator_id], references: [id])
  license_plate       String?  @db.VarChar(50)
  chassis_number      String?  @db.VarChar(100)
  engine_number       String?  @db.VarChar(100)
  debt_amount         Decimal  @default(0) @db.Decimal(15, 2)
  status              String   @default("active") @db.VarChar(20)
  liquidation_price   Decimal? @db.Decimal(15, 2)
  liquidation_buyer   String?  @db.VarChar(150)
  notes               String?  @db.Text
  created_at          DateTime @default(now()) @db.Timestamptz
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz
  lookup_token        String?  @db.VarChar(100)
  lookup_link         String?  @db.VarChar(255)

  interest_payments      PawnInterestPayment[]
  principal_transactions PawnPrincipalTransaction[]
  extensions             PawnContractExtension[]
  redemptions            PawnRedemption[]
  debt_history           PawnDebtHistory[]
  documents              PawnContractDocument[]
  debt_reminders         PawnDebtReminder[]
  transaction_ledgers    PawnTransactionLedger[]
  reminders              PawnContractReminder[]

  @@index([branch_id])
  @@index([customer_id])
  @@index([status])
  @@index([loan_date])
  @@index([created_at])
  @@map("pawn_contracts")
}

model PawnInterestPayment {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id        String   @db.Uuid
  contract           PawnContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  cycle_number       Int
  from_date          DateTime @db.Date
  to_date            DateTime @db.Date
  expected_days      Int
  expected_interest  Decimal  @default(0) @db.Decimal(15, 2)
  expected_principal Decimal  @default(0) @db.Decimal(15, 2)
  other_amount       Decimal  @default(0) @db.Decimal(15, 2)
  actual_paid        Decimal  @default(0) @db.Decimal(15, 2)
  paid_date          DateTime? @db.Date
  is_paid            Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz

  @@index([contract_id])
  @@index([is_paid])
  @@index([paid_date])
  @@index([from_date, to_date])
  @@map("pawn_interest_payments")
}

model PawnPrincipalTransaction {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id      String   @db.Uuid
  contract         PawnContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  transaction_date DateTime @db.Date
  type             String   @db.VarChar(20) // 'pay_down', 'borrow_more'
  amount           Decimal  @db.Decimal(15, 2)
  notes            String?  @db.Text
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("pawn_principal_transactions")
}

model PawnContractExtension {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id    String   @db.Uuid
  contract       PawnContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  from_date      DateTime @db.Date
  to_date        DateTime @db.Date
  extension_days Int
  content        String   @db.VarChar(255)
  notes          String?  @db.Text
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("pawn_contract_extensions")
}

model PawnRedemption {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id      String   @db.Uuid
  contract         PawnContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  redeem_date      DateTime @db.Date
  loan_amount      Decimal  @db.Decimal(15, 2)
  outstanding_debt Decimal  @db.Decimal(15, 2)
  interest_amount  Decimal  @db.Decimal(15, 2)
  other_amount     Decimal  @db.Decimal(15, 2)
  total_amount     Decimal  @db.Decimal(15, 2)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("pawn_redemptions")
}

model PawnDebtHistory {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id      String   @db.Uuid
  contract         PawnContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  transaction_date DateTime @db.Date
  type             String   @db.VarChar(20) // 'record_debt', 'pay_debt'
  amount           Decimal  @db.Decimal(15, 2)
  notes            String?  @db.Text
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("pawn_debt_history")
}

model PawnContractDocument {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id          String   @db.Uuid
  contract             PawnContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  document_type        String   @db.VarChar(30) // 'customer_photo', 'contract_document'
  image_url            String   @db.Text
  google_drive_file_id String?  @db.VarChar(100)
  file_name            String?  @db.VarChar(255)
  created_at           DateTime @default(now()) @db.Timestamptz
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("pawn_contract_documents")
}

model PawnDebtReminder {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id String   @db.Uuid
  contract    PawnContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  employee_id String   @db.Uuid
  employee    Employee @relation(fields: [employee_id], references: [id])
  content     String   @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("pawn_debt_reminders")
}

model PawnTransactionLedger {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id String   @db.Uuid
  contract    PawnContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  employee_id String   @db.Uuid
  employee    Employee @relation(fields: [employee_id], references: [id])
  debit_amount Decimal  @default(0) @db.Decimal(15, 2)
  credit_amount Decimal  @default(0) @db.Decimal(15, 2)
  other_amount Decimal  @default(0) @db.Decimal(15, 2)
  action_type String   @db.VarChar(50) // 'create_contract', 'pay_interest', etc.
  content     String   @db.Text
  notes       String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz

  @@index([contract_id])
  @@index([created_at])
  @@map("pawn_transaction_ledger")
}

model PawnContractReminder {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id   String   @db.Uuid
  contract      PawnContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  reminder_date DateTime @db.Date
  status        String   @default("active") @db.VarChar(20) // 'active', 'stopped', 'completed'
  content       String?  @db.Text
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("pawn_contract_reminders")
}


// ---------------- unsecured contracts ----------------
model UnsecuredContract {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id           String   @db.Uuid
  branch              Branch   @relation(fields: [branch_id], references: [id])
  contract_code       String   @unique @db.VarChar(50)
  customer_id         String   @db.Uuid
  customer            Customer @relation(fields: [customer_id], references: [id])
  commodity_id        String?  @db.Uuid
  commodity           Commodity? @relation(fields: [commodity_id], references: [id])
  loan_amount         Decimal  @default(0) @db.Decimal(15, 2)
  initial_loan_amount Decimal  @default(0) @db.Decimal(15, 2)
  interest_type_id    String   @db.Uuid
  interest_type       InterestType @relation(fields: [interest_type_id], references: [id])
  is_upfront_interest Boolean
  loan_days           Int
  period_value        Int
  interest_rate       Decimal  @db.Decimal(10, 2)
  loan_date           DateTime @db.Date
  collector_id        String   @db.Uuid
  collector           Employee @relation("collector_unsecured_contracts", fields: [collector_id], references: [id])
  collaborator_id     String?  @db.Uuid
  collaborator        Collaborator? @relation(fields: [collaborator_id], references: [id])
  debt_amount         Decimal  @default(0) @db.Decimal(15, 2)
  status              String   @default("active") @db.VarChar(20)
  notes               String?  @db.Text
  created_at          DateTime @default(now()) @db.Timestamptz
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz
  lookup_token        String?  @db.VarChar(100)
  lookup_link         String?  @db.VarChar(255)

  interest_payments      UnsecuredInterestPayment[]
  principal_transactions UnsecuredPrincipalTransaction[]
  extensions             UnsecuredContractExtension[]
  redemptions            UnsecuredRedemption[]
  debt_history           UnsecuredDebtHistory[]
  documents              UnsecuredContractDocument[]
  debt_reminders         UnsecuredDebtReminder[]
  transaction_ledgers    UnsecuredTransactionLedger[]
  reminders              UnsecuredContractReminder[]

  @@index([branch_id])
  @@index([customer_id])
  @@index([status])
  @@index([loan_date])
  @@map("unsecured_contracts")
}

model UnsecuredContractReminder {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id   String   @db.Uuid
  contract      UnsecuredContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  reminder_date DateTime @db.Date
  status        String   @default("active") @db.VarChar(20) // 'active', 'stopped', 'completed'
  content       String?  @db.Text
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("unsecured_contract_reminders")
}

model UnsecuredInterestPayment {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id        String   @db.Uuid
  contract           UnsecuredContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  cycle_number       Int
  from_date          DateTime @db.Date
  to_date            DateTime @db.Date
  expected_days      Int
  expected_interest  Decimal  @default(0) @db.Decimal(15, 2)
  expected_principal Decimal  @default(0) @db.Decimal(15, 2)
  other_amount       Decimal  @default(0) @db.Decimal(15, 2)
  actual_paid        Decimal  @default(0) @db.Decimal(15, 2)
  paid_date          DateTime? @db.Date
  is_paid            Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamptz
