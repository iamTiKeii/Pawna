# Backend API URL for local development proxy.
# By default, point to the local backend server (running on port 5001).
VITE_API_URL=http://localhost:5001

# Để kết nối tới server backend Production (ví dụ Railway), luôn sử dụng giao thức HTTPS để tránh lỗi CORS 301:
# VITE_API_URL=https://pawna-prod.up.railway.app
